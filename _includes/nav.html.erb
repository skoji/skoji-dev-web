<nav class="site-nav">
  <button class="nav-toggle" aria-label="Menu" aria-expanded="false"
    onclick="this.setAttribute('aria-expanded', this.getAttribute('aria-expanded') === 'false' ? 'true' : 'false')">
    <span class="hamburger"></span>
  </button>
  <div class="nav-menu">
    <div class="nav-links">
      <a href="<%= lang_path('/shelff/') %>">shelff</a>
      <a href="<%= lang_path('/about.html') %>">about</a>
    </div>
    <div class="lang-links">
      <% first = true %>
      <% page[:translations].each do |lang, url| %>
        <% unless first %>
          <span class="lang-sep">|</span>
        <% end %>
        <% first = false %>
        <% if page[:lang] == lang %>
          <span class="lang-current"><%= site.language_label(lang) %></span>
        <% else %>
          <a href="<%= url %>" lang="en"><%= site.language_label(lang) %></a>
        <% end %>
      <% end %>
    </div>
  </div>
</nav>
